# Build
build/
*.o
*.a

# Test output (baselines are tracked separately)
*.ppm
*.png
!/test/baselines/*.ppm
!/test/vrt/baselines/**/*.ppm
!/docs/images/*.png

# VRT run output (regenerated each run; baselines live under test/vrt/baselines/)
/test/vrt/output/
# Per-frame diff PPMs the VRT runner drops next to baselines on a failure
/test/vrt/baselines/diffs/

# Reference source (not part of build)
resources/DOOM/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store

# Tooling state
.claude/
.task/
