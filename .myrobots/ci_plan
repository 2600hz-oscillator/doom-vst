## CI workflow

`.github/workflows/ci.yml`:

```yaml
name: ci
on:
  push:
    branches: [main]
    tags: ['v*']
  pull_request:
    branches: [main]

jobs:
  build-test:
    runs-on: macos-14
    steps:
      - uses: actions/checkout@v4
        with: { submodules: recursive, lfs: true }
      - name: Install flox
        run: curl -fsSL https://downloads.flox.dev/by-env/stable/osx/flox-installer.pkg -o /tmp/flox.pkg && sudo installer -pkg /tmp/flox.pkg -target /
      - name: Cache build
        uses: actions/cache@v4
        with:
          path: build
          key: build-${{ runner.os }}-${{ hashFiles('CMakeLists.txt', 'extern/JUCE/CMakeLists.txt') }}
      - name: Configure + build
        run: flox activate -- bash -c 'task configure && cd build && cmake --build . -j8 --target DoomViz_VST3 doomviz_unit_tests doomviz_integration_tests doomviz_vrt_runner render_test'
      - name: Unit tests
        run: flox activate -- bash -c 'cd build && ctest -L unit --output-on-failure --output-junit unit-results.xml'
      - name: Integration tests
        run: flox activate -- bash -c 'cd build && ctest -L integration --output-on-failure --output-junit integration-results.xml'
      - name: Render baseline (existing)
        run: flox activate -- task test
      - name: Visual regression
        run: flox activate -- task vrt
      - name: Publish test results
        if: always()
        uses: EnricoMi/publish-unit-test-result-action/macos@v2
        with:
          junit_files: build/*-results.xml test/vrt/output/vrt-results.xml
      - name: Upload VRT artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: vrt-${{ github.sha }}
          path: |
            test/vrt/output/frame_*.ppm
            test/vrt/output/diffs/
            test/vrt/output/vrt-report.html
      - name: Upload unsigned VST3 (PR only)
        if: github.event_name == 'pull_request'
        uses: actions/upload-artifact@v4
        with:
          name: DoomViz-vst3-pr-${{ github.event.number }}
          path: build/DoomViz_artefacts/VST3/DoomViz.vst3

  release:
    needs: build-test
    if: startsWith(github.ref, 'refs/tags/v')
    runs-on: macos-14
    steps:
      - uses: actions/checkout@v4
        with: { submodules: recursive, lfs: true }
      - name: Import signing certificate
        env:
          P12_BASE64: ${{ secrets.MACOS_CERTIFICATE_P12_BASE64 }}
          P12_PASSWORD: ${{ secrets.MACOS_CERTIFICATE_PASSWORD }}
        run: |
          echo "$P12_BASE64" | base64 -d > /tmp/cert.p12
          security create-keychain -p ci ci.keychain
          security default-keychain -s ci.keychain
          security unlock-keychain -p ci ci.keychain
          security import /tmp/cert.p12 -k ci.keychain -P "$P12_PASSWORD" -T /usr/bin/codesign
          security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k ci ci.keychain
          rm /tmp/cert.p12
      - name: Install flox
        run: curl -fsSL https://downloads.flox.dev/... | sh
      - name: Build + sign
        run: flox activate -- task build-mac
      - name: Notarize + staple
        env:
          AC_API_KEY_ID: ${{ secrets.AC_API_KEY_ID }}
          AC_API_ISSUER_ID: ${{ secrets.AC_API_ISSUER_ID }}
          AC_API_KEY_P8: ${{ secrets.AC_API_KEY_P8 }}
        run: |
          echo "$AC_API_KEY_P8" > /tmp/key.p8
          flox activate -- task notarize-mac-ci  # new task, see below
      - name: Attach to release
        uses: softprops/action-gh-release@v2
        with:
          files: dist/DoomViz.vst3.zip
      - name: Cleanup keychain
        if: always()
        run: security delete-keychain ci.keychain
```

